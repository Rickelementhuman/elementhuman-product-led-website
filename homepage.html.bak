<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Element Human — What People See, Feel, Remember and How They Act Before You Invest</title>
  <meta name="description" content="Every other tool tells you what happened. Ellie tells you how people actually saw, felt, and remembered your content. Trusted by 211+ brands.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/styles.css">
  <link rel="stylesheet" href="css/homepage.css">
</head>
<body>

  <div class="bg-orbs" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>

  <nav class="nav" id="nav">
    <div class="nav-inner">
      <div class="nav-logo">
        <svg width="180" height="28" viewBox="0 0 180 28" fill="none">
          <circle cx="10" cy="14" r="9" fill="url(#gG)"/>
          <circle cx="26" cy="14" r="9" fill="url(#gP)"/>
          <circle cx="42" cy="14" r="9" fill="url(#gO)"/>
          <text x="56" y="20" fill="white" font-family="Poppins,sans-serif" font-weight="700" font-size="15">Element Human</text>
          <defs>
            <linearGradient id="gG" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#54E42B"/><stop offset="100%" stop-color="#10A8B7"/></linearGradient>
            <linearGradient id="gP" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#FF2198"/><stop offset="100%" stop-color="#8F21A1"/></linearGradient>
            <linearGradient id="gO" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#F9BE00"/><stop offset="100%" stop-color="#F60000"/></linearGradient>
          </defs>
        </svg>
      </div>
      <div class="nav-links">
        <a href="#pillar-measurement">How It Works</a>
        <a href="#final-cta" class="nav-cta">Book a Demo</a>
      </div>
      <button class="nav-hamburger" id="nav-hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
    <div class="nav-mobile" id="nav-mobile">
      <a href="#pillar-measurement">How It Works</a>
      <a href="#final-cta" class="nav-cta">Book a Demo</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hp-hero" id="hero">
    <div class="container hp-hero-inner">
      <h1>What people see, feel,<br>remember and how they act<br><span class="text-gradient">before you invest.</span></h1>
      <p class="hp-hero-sub">Ellie knows your audience &mdash; how they see, feel, and remember your stories. So every decision you make is backed by how people actually respond.</p>
      <div class="hp-hero-ctas">
        <a href="#final-cta" class="btn btn-primary btn-large">Book a Demo</a>
        <a href="#pillar-measurement" class="btn btn-outline btn-large">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF BAR -->
  <section class="hp-proof-bar" id="social-proof">
    <div class="container">
      <div class="logo-wall fade-up" id="logo-wall">
        <div class="logo-item" data-studies="5" data-tip="5 studies with Nike">Nike</div>
        <div class="logo-item" data-studies="8" data-tip="8 studies with Netflix">Netflix</div>
        <div class="logo-item" data-studies="4" data-tip="4 studies with Amazon">Amazon</div>
        <div class="logo-item" data-studies="9" data-tip="9 studies with T-Mobile">T-Mobile</div>
        <div class="logo-item" data-studies="3" data-tip="3 studies with BBC">BBC</div>
        <div class="logo-item" data-studies="2" data-tip="2 studies with Coca-Cola">Coca-Cola</div>
        <div class="logo-item" data-studies="2" data-tip="2 studies with Spotify">Spotify</div>
        <div class="logo-item" data-studies="3" data-tip="3 studies with P&amp;G">P&amp;G</div>
      </div>
      <div class="stats-bar fade-up">
        <div class="stat"><div class="stat-value" data-target="341">0</div><div class="stat-label">studies completed</div></div>
        <div class="stat"><div class="stat-value-text">211+</div><div class="stat-label">brands trust Ellie</div></div>
        <div class="stat"><div class="stat-value-text">8+</div><div class="stat-label">global markets</div></div>
      </div>
    </div>
  </section>

  <!-- Detail: Measurement (hidden by default) -->
  <section class="hp-product" id="detail-measurement">
    <div class="aha-ambient" aria-hidden="true">
      <div class="aha-orb aha-orb-1"></div>
      <div class="aha-orb aha-orb-2"></div>
    </div>
    <div class="hp-scroller" id="hp-scroller">
      <div class="hp-pinned">
        <div class="hp-aha-split">

          <!-- LEFT: narration + progress -->
          <div class="hp-aha-left">
            <div class="hp-story-col">
              <div class="story-card active" data-step="0">
                <span class="pill pill-blue">ATTENTION</span>
                <h2>Were they watching?</h2>
                <p>Eye tracking reveals exactly where your audience looked — and what they missed entirely.</p>
                <p class="insight"><strong>87%</strong> noticed the product. Only <strong>12%</strong> saw your logo.</p>
              </div>
              <div class="story-card" data-step="1">
                <span class="pill pill-pink">EMOTION</span>
                <h2>How did they react?</h2>
                <p>Second-by-second emotional response shows which moments resonate and which fall flat.</p>
                <p class="insight">Peak engagement at <strong>0:08</strong>. Attention drops at <strong>0:18</strong> — the brand mention feels forced.</p>
              </div>
              <div class="story-card" data-step="2">
                <span class="pill pill-teal">MEMORY</span>
                <h2>Will they remember?</h2>
                <p>Implicit memory testing measures what sticks — not what people say, but what they actually retained.</p>
                <p class="insight"><strong>78%</strong> recognized the brand. Only <strong>31%</strong> recalled the product unaided.</p>
              </div>
              <div class="story-card" data-step="3">
                <span class="pill pill-green">BRAND UPLIFT</span>
                <h2>Did it move the needle?</h2>
                <p>The final proof: did this creative change how people think and intend to act?</p>
                <p class="insight"><strong>+24pt</strong> favorability. <strong>+12pt</strong> purchase intent. It works — but the logo needs repositioning.</p>
              </div>
            </div>

            <div class="dots-row">
              <div class="dot active" data-s="0"><span>Attention</span></div>
              <div class="dot" data-s="1"><span>Emotion</span></div>
              <div class="dot" data-s="2"><span>Memory</span></div>
              <div class="dot" data-s="3"><span>Uplift</span></div>
            </div>
          </div>

          <!-- RIGHT: video + overlays + chart -->
          <div class="hp-aha-right">
            <div class="creative-wrap" id="hp-creative-wrap">
              <div class="phase-sweep" id="hp-phase-sweep"></div>
              <video id="hp-bg-video" class="bg-video"
                src="video/creative.mp4"
                muted playsinline preload="auto"
                disablepictureinpicture></video>
              <div class="c-controls">
                <span class="c-play">&#9654;</span>
                <span class="c-time" id="hp-c-time">0:00</span>
                <div class="c-bar"><div class="c-bar-fill" id="hp-c-bar-fill"></div></div>
                <span class="c-dur" id="hp-c-dur">0:00</span>
              </div>

              <div id="hp-heat-dim" class="layer heat-dim"></div>
              <canvas id="hp-heat" class="layer layer-heat"></canvas>

              <div class="layer layer-memory" id="hp-layer-memory">
                <div class="mem-card">
                  <div class="mem-title">Implicit Memory Test</div>
                  <div class="mem-row"><span>Brand Logo Recognition</span><span class="mem-val" id="hp-mv-logo">0%</span></div>
                  <div class="mem-track"><div class="mem-fill" id="hp-mf-logo"></div></div>
                  <div class="mem-row"><span>Product Recall (Aided)</span><span class="mem-val" id="hp-mv-aided">0%</span></div>
                  <div class="mem-track"><div class="mem-fill" id="hp-mf-aided"></div></div>
                  <div class="mem-row"><span>Product Recall (Unaided)</span><span class="mem-val" id="hp-mv-unaided">0%</span></div>
                  <div class="mem-track"><div class="mem-fill" id="hp-mf-unaided"></div></div>
                  <div class="mem-row"><span>Key Message Retention</span><span class="mem-val" id="hp-mv-message">0%</span></div>
                  <div class="mem-track"><div class="mem-fill" id="hp-mf-message"></div></div>
                </div>
              </div>

              <div class="layer layer-uplift" id="hp-layer-uplift">
                <div class="uplift-card">
                  <div class="uplift-head">Brand Uplift Results</div>
                  <div class="uplift-sub">Exposed vs. Control &middot; 95% confidence</div>
                  <div class="uplift-grid">
                    <div class="u-metric">
                      <div class="u-val" id="hp-uv-aw" data-t="14">+0</div>
                      <div class="u-label">Awareness</div>
                      <span class="u-sig">Significant</span>
                    </div>
                    <div class="u-metric">
                      <div class="u-val" id="hp-uv-fav" data-t="24">+0</div>
                      <div class="u-label">Favorability</div>
                      <span class="u-sig">Significant</span>
                    </div>
                    <div class="u-metric">
                      <div class="u-val" id="hp-uv-con" data-t="18">+0</div>
                      <div class="u-label">Consideration</div>
                      <span class="u-sig">Significant</span>
                    </div>
                    <div class="u-metric">
                      <div class="u-val" id="hp-uv-int" data-t="12">+0</div>
                      <div class="u-label">Purchase Intent</div>
                      <span class="u-sig">Significant</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="emotion-wrap layer" id="hp-layer-emotion">
              <div class="emotion-chart-wrap">
                <svg viewBox="0 0 1000 300" preserveAspectRatio="none" class="emotion-svg">
                  <line x1="10" y1="25" x2="990" y2="25" class="gl"/>
                  <line x1="10" y1="85" x2="990" y2="85" class="gl"/>
                  <line x1="10" y1="150" x2="990" y2="150" class="gl"/>
                  <line x1="10" y1="215" x2="990" y2="215" class="gl"/>
                  <line x1="10" y1="275" x2="990" y2="275" class="gl"/>
                  <path id="hp-c-att" class="curve c-blue"
                    d="M10,255 C100,254 180,250 250,242 C320,225 350,170 400,100 C450,80 500,85 550,120 C620,170 700,215 780,240 C860,250 940,254 990,255"/>
                  <path id="hp-c-val" class="curve c-teal"
                    d="M10,260 C100,258 200,254 300,245 C380,225 430,185 490,145 C550,140 600,155 660,185 C730,218 800,242 880,254 C940,258 970,260 990,260"/>
                  <path id="hp-c-hap" class="curve c-green"
                    d="M10,270 C120,268 220,264 310,255 C380,240 430,205 490,160 C540,130 580,118 620,125 C680,150 740,200 800,240 C860,258 930,267 990,270"/>
                  <path id="hp-c-sur" class="curve c-amber"
                    d="M10,275 C80,274 140,273 190,270 C230,262 260,230 300,185 C340,210 370,258 420,272 C470,275 520,274 570,270 C610,258 650,210 700,165 C740,200 770,255 820,272 C870,275 940,275 990,275"/>
                  <path id="hp-c-ang" class="curve c-red"
                    d="M10,280 C150,280 260,278 350,275 C420,270 470,262 520,256 C570,262 620,272 700,278 C800,280 900,280 990,280"/>
                  <line id="hp-playhead" class="ph" x1="10" y1="18" x2="10" y2="282"/>
                  <circle id="hp-peak-dot" class="pk-dot" cx="400" cy="100" r="5"/>
                </svg>
                <span id="hp-peak-label" class="pk-label">Peak engagement</span>
              </div>
              <div class="legend" id="hp-legend">
                <span><i class="d d-blue"></i>attention</span>
                <span><i class="d d-teal"></i>valence</span>
                <span><i class="d d-green"></i>happiness</span>
                <span><i class="d d-amber"></i>surprise</span>
                <span><i class="d d-red"></i>anger</span>
              </div>
            </div>

          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- HUMAN DATA — THE FOUNDATION -->
  <section class="pillar-section pillar-measurement pillar-foundation" id="pillar-measurement">
    <div class="pillar-inner">
      <div class="pillar-text">
        <span class="eyebrow fade-up">THE FOUNDATION</span>
        <h2 class="pillar-title fade-up">Human Data</h2>
        <p class="pillar-question fade-up">The base layer everything else builds on.</p>
        <p class="pillar-desc fade-up">Attention, emotion, memory, brand uplift &mdash; every insight across every pillar starts here. This is how we understand what your audience actually sees, feels, and remembers.</p>
      </div>
      <div class="pillar-graphic fade-up">
        <svg class="metrics-chart" viewBox="0 0 400 400">
          <defs>
            <linearGradient id="measurement-grad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#54E42B"/>
              <stop offset="100%" stop-color="#007AFF"/>
            </linearGradient>
            <linearGradient id="measurement-area-grad" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" stop-color="rgba(84,228,43,0.15)"/>
              <stop offset="100%" stop-color="rgba(0,122,255,0)"/>
            </linearGradient>
          </defs>
          <!-- Bar labels -->
          <text class="metric-label" x="20" y="58">Attention</text>
          <text class="metric-label" x="20" y="108">Emotion</text>
          <text class="metric-label" x="20" y="158">Memory</text>
          <!-- Bar backgrounds -->
          <rect class="metric-bar-bg" x="100" y="42" width="280" height="22"/>
          <rect class="metric-bar-bg" x="100" y="92" width="280" height="22"/>
          <rect class="metric-bar-bg" x="100" y="142" width="280" height="22"/>
          <!-- Bar fills (animated via JS) -->
          <rect class="metric-bar-fill" x="100" y="42" width="0" height="22" data-width="238"/>
          <rect class="metric-bar-fill" x="100" y="92" width="0" height="22" data-width="196"/>
          <rect class="metric-bar-fill" x="100" y="142" width="0" height="22" data-width="224"/>
          <!-- Values -->
          <text class="metric-value" x="380" y="58" data-target="85">0%</text>
          <text class="metric-value" x="380" y="108" data-target="70">0%</text>
          <text class="metric-value" x="380" y="158" data-target="80">0%</text>
          <!-- Emotion curve -->
          <path class="metric-curve-area" d="M40,240 Q100,220 140,260 T240,230 T340,250 L340,360 L40,360 Z"/>
          <path class="metric-curve" d="M40,240 Q100,220 140,260 T240,230 T340,250"/>
          <!-- Axis -->
          <line x1="40" y1="360" x2="360" y2="360" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
          <text class="metric-label" x="180" y="390">Emotional Timeline</text>
        </svg>
      </div>
    </div>
  </section>

  <!-- PILLAR 01: DISTRIBUTION -->
  <section class="pillar-section pillar-distribution" id="pillar-distribution">
    <div class="pillar-inner">
      <div class="pillar-text">
        <span class="eyebrow fade-up">01</span>
        <h2 class="pillar-title fade-up">Distribution</h2>
        <p class="pillar-question fade-up">Where do I tell my story?</p>
        <p class="pillar-desc fade-up">Stopping power and staying power across every platform &mdash; TikTok, Instagram, YouTube, CTV. See which content stops the scroll, which keeps them watching, and where your budget should go.</p>
      </div>
      <div class="pillar-graphic fade-up">
        <svg class="ripple-broadcast" viewBox="0 0 400 400">
          <defs>
            <linearGradient id="distribution-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#10A8B7"/>
              <stop offset="100%" stop-color="#54E42B"/>
            </linearGradient>
          </defs>
          <circle class="ripple-ring" cx="200" cy="200" r="180"/>
          <circle class="ripple-ring" cx="200" cy="200" r="180"/>
          <circle class="ripple-ring" cx="200" cy="200" r="180"/>
          <circle class="ripple-ring" cx="200" cy="200" r="180"/>
          <circle class="ripple-ring" cx="200" cy="200" r="180"/>
          <text class="ripple-label" x="340" y="120">Social</text>
          <text class="ripple-label" x="80" y="310">CTV</text>
          <text class="ripple-label" x="330" y="300">Display</text>
          <text class="ripple-label" x="90" y="130">Audio</text>
          <circle class="ripple-center" cx="200" cy="200" r="8"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- Detail: Distribution (hidden by default) -->
  <section class="ssp-section" id="detail-distribution">
    <div class="container">
      <div class="ssp-header fade-up">
        <span class="pill pill-green">STOPPING &amp; STAYING POWER&trade;</span>
        <h2 class="section-headline">Which content <span class="text-gradient">stops the scroll?</span></h2>
        <p class="ssp-subtitle">Every dot is a creative. Ellie's SSP score predicts which content will stop viewers and keep them watching.</p>
      </div>

      <div class="ssp-card glass-card fade-up" id="ssp-card">
        <svg class="ssp-chart" viewBox="0 0 800 600" preserveAspectRatio="xMidYMid meet">
          <!-- Grid lines -->
          <g class="ssp-grid">
            <line x1="60" y1="40" x2="60" y2="540" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
            <line x1="200" y1="40" x2="200" y2="540" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
            <line x1="340" y1="40" x2="340" y2="540" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
            <line x1="480" y1="40" x2="480" y2="540" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
            <line x1="620" y1="40" x2="620" y2="540" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
            <line x1="760" y1="40" x2="760" y2="540" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
            <line x1="60" y1="40" x2="760" y2="40" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
            <line x1="60" y1="140" x2="760" y2="140" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
            <line x1="60" y1="240" x2="760" y2="240" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
            <line x1="60" y1="340" x2="760" y2="340" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
            <line x1="60" y1="440" x2="760" y2="440" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
            <line x1="60" y1="540" x2="760" y2="540" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
          </g>
          <!-- Quadrant dividers (dashed at 50/50) -->
          <line x1="410" y1="40" x2="410" y2="540" stroke="rgba(255,255,255,.2)" stroke-width="1.5" stroke-dasharray="6 4"/>
          <line x1="60" y1="290" x2="760" y2="290" stroke="rgba(255,255,255,.2)" stroke-width="1.5" stroke-dasharray="6 4"/>
          <!-- Quadrant labels -->
          <text x="585" y="165" text-anchor="middle" fill="rgba(84,228,43,.15)" font-size="14" font-family="'Poppins',sans-serif" font-weight="600">HIGH STOP &amp; STAY</text>
          <text x="235" y="165" text-anchor="middle" fill="rgba(249,190,0,.12)" font-size="14" font-family="'Poppins',sans-serif" font-weight="600">HIGH STOP</text>
          <text x="585" y="465" text-anchor="middle" fill="rgba(0,122,255,.12)" font-size="14" font-family="'Poppins',sans-serif" font-weight="600">HIGH STAY</text>
          <text x="235" y="465" text-anchor="middle" fill="rgba(246,0,0,.1)" font-size="14" font-family="'Poppins',sans-serif" font-weight="600">LOW</text>
          <!-- Axis labels -->
          <text x="410" y="585" text-anchor="middle" fill="rgba(255,255,255,.5)" font-size="13" font-family="'JetBrains Mono',monospace">Staying Power →</text>
          <text x="18" y="290" text-anchor="middle" fill="rgba(255,255,255,.5)" font-size="13" font-family="'JetBrains Mono',monospace" transform="rotate(-90,18,290)">Stopping Power ↑</text>
          <!-- Tick labels: X axis -->
          <text x="60" y="565" text-anchor="middle" fill="rgba(255,255,255,.35)" font-size="11" font-family="'JetBrains Mono',monospace">0</text>
          <text x="200" y="565" text-anchor="middle" fill="rgba(255,255,255,.35)" font-size="11" font-family="'JetBrains Mono',monospace">20</text>
          <text x="340" y="565" text-anchor="middle" fill="rgba(255,255,255,.35)" font-size="11" font-family="'JetBrains Mono',monospace">40</text>
          <text x="480" y="565" text-anchor="middle" fill="rgba(255,255,255,.35)" font-size="11" font-family="'JetBrains Mono',monospace">60</text>
          <text x="620" y="565" text-anchor="middle" fill="rgba(255,255,255,.35)" font-size="11" font-family="'JetBrains Mono',monospace">80</text>
          <text x="760" y="565" text-anchor="middle" fill="rgba(255,255,255,.35)" font-size="11" font-family="'JetBrains Mono',monospace">100</text>
          <!-- Tick labels: Y axis -->
          <text x="50" y="544" text-anchor="end" fill="rgba(255,255,255,.35)" font-size="11" font-family="'JetBrains Mono',monospace">0</text>
          <text x="50" y="444" text-anchor="end" fill="rgba(255,255,255,.35)" font-size="11" font-family="'JetBrains Mono',monospace">20</text>
          <text x="50" y="344" text-anchor="end" fill="rgba(255,255,255,.35)" font-size="11" font-family="'JetBrains Mono',monospace">40</text>
          <text x="50" y="244" text-anchor="end" fill="rgba(255,255,255,.35)" font-size="11" font-family="'JetBrains Mono',monospace">60</text>
          <text x="50" y="144" text-anchor="end" fill="rgba(255,255,255,.35)" font-size="11" font-family="'JetBrains Mono',monospace">80</text>
          <text x="50" y="44" text-anchor="end" fill="rgba(255,255,255,.35)" font-size="11" font-family="'JetBrains Mono',monospace">100</text>
          <!-- Data dots: cx = 60 + (x/100)*700, cy = 540 - (y/100)*500 -->
          <!-- #9: x=18,y=25 Red -->
          <circle class="ssp-dot" cx="186" cy="415" r="8" fill="#F60000" opacity="0"/>
          <!-- #7: x=35,y=32 Red -->
          <circle class="ssp-dot" cx="304.5" cy="380" r="8" fill="#F60000" opacity="0"/>
          <!-- #5: x=28,y=62 Amber -->
          <circle class="ssp-dot" cx="256" cy="230" r="8" fill="#F9BE00" opacity="0"/>
          <!-- #3: x=45,y=78 Amber -->
          <circle class="ssp-dot" cx="374.5" cy="150" r="8" fill="#F9BE00" opacity="0"/>
